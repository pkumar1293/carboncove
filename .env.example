# Supabase (Auth only — DB runs on VPS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (local PostgreSQL on VPS)
DATABASE_URL=postgresql://carboncove:YOUR_PASSWORD@localhost:5432/carboncove

# Redis (local on VPS)
REDIS_URL=redis://localhost:6379

# Payments & email
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RESEND_API_KEY=

# App
NEXT_PUBLIC_API_URL=https://api.carboncove.in
NEXTAUTH_SECRET=

# Defaults (overridden by app_config table in DB at runtime)
EU_ETS_PRICE_EUR=80
EUR_TO_INR_RATE=90
