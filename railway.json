{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "heroku.buildpacks"
  },
  "deploy": {
    "startCommand": "cd apps/web && pnpm start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 60,
    "healthchecks": {
      "readiness": {
        "initialDelaySeconds": 10,
        "periodSeconds": 10,
        "timeoutSeconds": 5
      }
    }
  }
}
